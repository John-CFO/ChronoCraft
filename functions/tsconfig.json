{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "es2020",
    "module": "node16",
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "types": ["node", "@firebase/rules-unit-testing"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "lib", "dist", "tests"]
}
