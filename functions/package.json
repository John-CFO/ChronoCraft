{
  "name": "functions",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:e2e": "jest --config=jest.e2e.config.js tests/e2e --runInBand",
    "test:unit": "jest --config=jest.unit.config.js",
    "test:integration": "firebase emulators:exec --only functions,auth,firestore,storage \"jest --config=jest.integration.config.js\"",
    "test:integration:user": "jest tests/integration/repos/userRepo.integration.ts --config=jest.integration.config.js",
    "emulators": "firebase emulators:start --only firestore,auth --project=test-project"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^25.6.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.3"
  },
  "private": true,
  "directories": {
    "lib": "lib"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
