{
  "extends": "./node_modules/expo/tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "jsx": "react-native",
    "lib": ["esnext"],
    "outDir": "lib",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["@react-native-async-storage/async-storage", "node", "jest"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "validation/overrides/firestore.override.js"
  ],
  "exclude": ["node_modules", "functions"],
  "rootDir": "./"
}
